---
permalink: /projects/
layout: page.njk
title_sv: Projekt — Joel Takahashi Olsson
title_en: Projects — Joel Takahashi Olsson
---
{% for section in collections.contentSections | filterSections(["projects"]) %}
<section id="{{ section.id }}">
{% if section.title_sv %}<h2><span data-sv>{{ section.title_sv }}</span><span data-en>{{ section.title_en }}</span></h2>{% endif %}
{% for entry in section.entries %}{{ entry.templateContent | safe }}{% endfor %}
</section>
{% endfor %}
<script>
document.querySelectorAll('main section p').forEach(p => {
  const title = p.querySelector('b');
  if (!title) return;
  const details = document.createElement('span');
  [...p.childNodes].forEach(node => { if (node !== title) details.appendChild(node); });
  details.style.cssText = 'display:block;max-width:560px;padding:0.05em 1em;margin:auto';
  p.appendChild(details);
});
</script>
