<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Joel Takahashi Olsson</title>
<link rel="stylesheet" href="/style.css">
<script>const l=localStorage.getItem('lang');if(l)document.documentElement.setAttribute('lang',l);</script>
</head>
<body>
<header></header>
<script src="/partials/header.js"></script>
<br>

<main>
{% for section in collections.contentSections | filterSections(["contact"]) %}
<section id="{{ section.id }}">
{% if section.title_sv %}<h2><span data-sv>{{ section.title_sv }}</span><span data-en>{{ section.title_en }}</span></h2>{% endif %}
{% for entry in section.entries %}{{ entry.templateContent | safe }}{% endfor %}
</section>
{% endfor %}
</main>

<br>
<br>
<br>
<br>
<br>
<footer></footer>
<script src="/partials/footer.js"></script>

</body>
</html>
